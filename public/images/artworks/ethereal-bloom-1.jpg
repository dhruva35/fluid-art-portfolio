<svg xmlns="http://www.w3.org/2000/svg" width="800" height="1000" viewBox="0 0 800 1000">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f5b7b1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#d7bde2;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#fdfefe;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="bloom" cx="40%" cy="45%" r="40%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.6" />
      <stop offset="100%" style="stop-color:#f5b7b1;stop-opacity:0" />
    </radialGradient>
  </defs>
  <rect width="800" height="1000" fill="url(#bg)"/>
  <ellipse cx="350" cy="450" rx="200" ry="220" fill="url(#bloom)"/>
  <text x="400" y="950" font-family="Georgia,serif" font-size="20" fill="#6c3483" text-anchor="middle" opacity="0.5">Ethereal Bloom</text>
</svg>
