<svg xmlns="http://www.w3.org/2000/svg" width="800" height="1000" viewBox="0 0 800 1000">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#148f77;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#1abc9c;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2e86c1;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="coral" cx="50%" cy="50%" r="45%">
      <stop offset="0%" style="stop-color:#e74c3c;stop-opacity:0.4" />
      <stop offset="100%" style="stop-color:#148f77;stop-opacity:0" />
    </radialGradient>
  </defs>
  <rect width="800" height="1000" fill="url(#bg)"/>
  <ellipse cx="400" cy="500" rx="250" ry="280" fill="url(#coral)"/>
  <text x="400" y="950" font-family="Georgia,serif" font-size="20" fill="white" text-anchor="middle" opacity="0.5">Coral Reef</text>
</svg>
