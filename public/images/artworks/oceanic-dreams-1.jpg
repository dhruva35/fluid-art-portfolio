<svg xmlns="http://www.w3.org/2000/svg" width="800" height="1000" viewBox="0 0 800 1000">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a5276;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#2e86c1;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#85c1e9;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="glow1" cx="30%" cy="40%" r="40%">
      <stop offset="0%" style="stop-color:#aed6f1;stop-opacity:0.6" />
      <stop offset="100%" style="stop-color:#1a5276;stop-opacity:0" />
    </radialGradient>
    <radialGradient id="glow2" cx="70%" cy="60%" r="35%">
      <stop offset="0%" style="stop-color:#d4efdf;stop-opacity:0.4" />
      <stop offset="100%" style="stop-color:#2e86c1;stop-opacity:0" />
    </radialGradient>
  </defs>
  <rect width="800" height="1000" fill="url(#bg)"/>
  <ellipse cx="240" cy="400" rx="200" ry="250" fill="url(#glow1)"/>
  <ellipse cx="560" cy="600" rx="180" ry="220" fill="url(#glow2)"/>
  <circle cx="400" cy="500" r="120" fill="#1a5276" opacity="0.3"/>
  <text x="400" y="950" font-family="Georgia,serif" font-size="20" fill="white" text-anchor="middle" opacity="0.5">Oceanic Dreams</text>
</svg>
