<svg xmlns="http://www.w3.org/2000/svg" width="800" height="1000" viewBox="0 0 800 1000">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#dc7633;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#ba4a00;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e8449;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="1000" fill="url(#bg)"/>
  <circle cx="300" cy="400" r="150" fill="#f0b27a" opacity="0.3"/>
  <circle cx="500" cy="600" r="120" fill="#1e8449" opacity="0.3"/>
  <text x="400" y="950" font-family="Georgia,serif" font-size="20" fill="white" text-anchor="middle" opacity="0.5">Autumn Whisper</text>
</svg>
