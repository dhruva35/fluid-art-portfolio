<svg xmlns="http://www.w3.org/2000/svg" width="800" height="1000" viewBox="0 0 800 1000">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a5276;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#2c3e50;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#5b2c6f;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="sap" cx="50%" cy="40%" r="40%">
      <stop offset="0%" style="stop-color:#85c1e9;stop-opacity:0.5" />
      <stop offset="100%" style="stop-color:#1a5276;stop-opacity:0" />
    </radialGradient>
  </defs>
  <rect width="800" height="1000" fill="url(#bg)"/>
  <ellipse cx="400" cy="400" rx="220" ry="250" fill="url(#sap)"/>
  <text x="400" y="950" font-family="Georgia,serif" font-size="20" fill="white" text-anchor="middle" opacity="0.5">Sapphire Veil</text>
</svg>
